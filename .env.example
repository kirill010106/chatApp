# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=8080
# Production: set to your server IP or domain, e.g. http://185.65.200.160 or https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# VAPID (Web Push) — generate with: go run backend/cmd/genkeys/main.go
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# S3-compatible storage (optional — media uploads disabled if empty)
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=chatapp-media
S3_REGION=us-east-1
